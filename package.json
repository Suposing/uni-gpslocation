{
  "id": "uni-gpslocation",
  "displayName": "GPS定位 前后台定位 后台持续定位",
  "version": "0.0.1",
  "description": "UTS 插件，支持 Android/iOS 前台定位、后台定位、息屏持续定位与最近位置获取。",
